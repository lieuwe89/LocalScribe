{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "locallexis-sidecar", "sidecar": true }]
    },
    "shell:allow-open",
    "updater:default",
    "process:default"
  ]
}
