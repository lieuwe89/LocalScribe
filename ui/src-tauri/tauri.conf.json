{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "locallexis",
  "version": "0.6.3",
  "identifier": "dev.locallexis.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "locallexis",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": ["resources/models/**/*"],
    "externalBin": ["binaries/locallexis-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lieuwe89/LocalLexis/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIyRDhDNzI4Njg3OUQwNUIKUldSYjBIbG9LTWZZc21JOCt2bnk5KzUrc0Fwa3MvVjF1bzhpWDZ4VXpwc25DanR0M3F3TkhKSXIK"
    }
  }
}
